# Superpos
SUPERPOS_BASE_URL=https://your-superpos-instance.com
SUPERPOS_HIVE_ID=your-hive-id
SUPERPOS_AGENT_ID=your-agent-id
SUPERPOS_API_TOKEN=your-api-token
SUPERPOS_REFRESH_TOKEN=your-refresh-token
SUPERPOS_CAPABILITIES=code,review
SUPERPOS_POLL_INTERVAL=5

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ALLOWED_USERS=123456789,987654321
TELEGRAM_CHAT_ID=your-default-chat-id

# Gemini
# Auth: either set GEMINI_API_KEY (Google AI Studio key), or use OAuth by running:
#   docker run -it -v gemini_auth:/home/agent/.gemini --entrypoint gemini slim-gemini-agent auth login
# and following the prompts.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
# Reasoning effort maps to Gemini's "thinking" budget — low|medium|high
GEMINI_REASONING_EFFORT=medium
GEMINI_MAX_TURNS=30
EXECUTOR_WORKING_DIR=/workspace

# Optional: voice-note transcription falls back to OpenAI Whisper.
# Set this if you want /voice messages from Telegram to be transcribed.
VOICE_TRANSCRIBE_API_KEY=

# Git / GitHub (for coding tasks: clone, push, PRs)
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=you@example.com
GITHUB_TOKEN=ghp_your-personal-access-token
